<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F3F3"
    android:fitsSystemWindows="true"
    tools:context=".HomeActivity">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="12dp"
            android:paddingEnd="24dp"
            android:paddingBottom="12dp">

            <!-- Logo -->
            <ImageView
                android:id="@+id/logoImage"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:contentDescription="SaysAI Logo"
                android:scaleType="fitCenter"
                android:src="@mipmap/saysai_logo" />

            <!-- Header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="2dp"
                android:paddingEnd="2dp">

                <TextView
                    android:id="@+id/tvHomeTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/sf_pro_bold"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.01"
                    android:text="Home"
                    android:textColor="#4A4A4A"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivSettings"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="Settings"
                    android:src="@drawable/ic_settings_home"
                    app:tint="#4A4A4A" />
            </LinearLayout>

            <!-- Welcome card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/welcomeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="#0D84A5"
                app:cardCornerRadius="22dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/sf_pro_bold"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.005"
                        android:text="Welcome to SaysAI!"
                        android:textColor="#FFFFFF"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/sf_pro_regular"
                        android:includeFontPadding="false"
                        android:letterSpacing="0"
                        android:lineSpacingExtra="1dp"
                        android:text="SaysAI is an AI-powered application that translates sign language videos into natural language text using gesture recognition and language processing, promoting accessible and inclusive communication."
                        android:textColor="#FFFFFF"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Learn section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvLearnTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/sf_pro_bold"
                    android:includeFontPadding="false"
                    android:text="Learn a sign language"
                    android:textColor="#4A4A4A"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/sf_pro_medium"
                    android:includeFontPadding="false"
                    android:text="See all"
                    android:textColor="#C98E82"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardFsl"
                        android:layout_width="260dp"
                        android:layout_height="180dp"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="6dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="FSL Flag"
                                android:scaleType="centerCrop"
                                android:src="@drawable/flag_fsl" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#668A9BA7"
                                android:gravity="bottom|start"
                                android:orientation="vertical"
                                android:paddingStart="18dp"
                                android:paddingTop="18dp"
                                android:paddingEnd="18dp"
                                android:paddingBottom="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/sf_pro_bold"
                                    android:includeFontPadding="false"
                                    android:text="FSL"
                                    android:textColor="#FFFFFF"
                                    android:textSize="34sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/sf_pro_regular"
                                    android:includeFontPadding="false"
                                    android:text="Filipino Sign Language"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp" />
                            </LinearLayout>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardAsl"
                        android:layout_width="260dp"
                        android:layout_height="180dp"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="6dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="ASL Flag"
                                android:scaleType="centerCrop"
                                android:src="@drawable/flag_asl" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#668A9BA7"
                                android:gravity="bottom|start"
                                android:orientation="vertical"
                                android:paddingStart="18dp"
                                android:paddingTop="18dp"
                                android:paddingEnd="18dp"
                                android:paddingBottom="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/sf_pro_bold"
                                    android:includeFontPadding="false"
                                    android:text="ASL"
                                    android:textColor="#FFFFFF"
                                    android:textSize="34sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/sf_pro_regular"
                                    android:includeFontPadding="false"
                                    android:text="American Sign Language"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp" />
                            </LinearLayout>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardBsl"
                        android:layout_width="260dp"
                        android:layout_height="180dp"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="6dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="BSL Flag"
                                android:scaleType="centerCrop"
                                android:src="@drawable/flag_bsl" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#668A9BA7"
                                android:gravity="bottom|start"
                                android:orientation="vertical"
                                android:paddingStart="18dp"
                                android:paddingTop="18dp"
                                android:paddingEnd="18dp"
                                android:paddingBottom="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/sf_pro_bold"
                                    android:includeFontPadding="false"
                                    android:text="BSL"
                                    android:textColor="#FFFFFF"
                                    android:textSize="34sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/sf_pro_regular"
                                    android:includeFontPadding="false"
                                    android:text="British Sign Language"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp" />
                            </LinearLayout>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Supported languages -->
            <TextView
                android:id="@+id/tvSupportedTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/sf_pro_bold"
                android:includeFontPadding="false"
                android:text="Supported languages"
                android:textColor="#4A4A4A"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAslSupported"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="ASL Flag"
                        android:scaleType="centerCrop"
                        android:src="@drawable/flag_asl" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#668A9BA7"
                        android:gravity="bottom|start"
                        android:orientation="vertical"
                        android:paddingStart="20dp"
                        android:paddingTop="20dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/sf_pro_bold"
                            android:includeFontPadding="false"
                            android:text="ASL"
                            android:textColor="#FFFFFF"
                            android:textSize="36sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/sf_pro_regular"
                            android:includeFontPadding="false"
                            android:text="American Sign Language"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom navigation -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNav"
        android:layout_width="wrap_content"
        android:layout_height="70dp"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="#0D84A5"
        app:cardCornerRadius="35dp"
        app:cardElevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="8dp"
            android:paddingEnd="18dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/navHome"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="26dp"
                android:background="@drawable/nav_selected_circle"
                android:padding="10dp"
                android:src="@drawable/ic_nav_home"
                app:tint="#0D84A5" />

            <ImageView
                android:id="@+id/navCamera"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginEnd="26dp"
                android:background="@android:color/transparent"
                android:padding="4dp"
                android:src="@drawable/ic_nav_camera"
                app:tint="@android:color/white" />

            <ImageView
                android:id="@+id/navArchive"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@android:color/transparent"
                android:padding="4dp"
                android:src="@drawable/ic_nav_archive"
                app:tint="@android:color/white" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/tutorialOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#F3F3F3"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="140dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/tutorialBackButton"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="Back"
                        android:src="@drawable/ic_back_result"
                        app:tint="#4A4A4A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="@font/sf_pro_bold"
                        android:includeFontPadding="false"
                        android:text="Learn a sign language"
                        android:textColor="#4A4A4A"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/overlayCardFsl"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="FSL Flag"
                            android:scaleType="centerCrop"
                            android:src="@drawable/flag_fsl" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#668A9BA7"
                            android:gravity="bottom|start"
                            android:orientation="vertical"
                            android:paddingStart="18dp"
                            android:paddingTop="18dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/sf_pro_bold"
                                android:includeFontPadding="false"
                                android:text="FSL"
                                android:textColor="#FFFFFF"
                                android:textSize="34sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/sf_pro_regular"
                                android:includeFontPadding="false"
                                android:text="Filipino Sign Language"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/overlayCardBsl"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="BSL Flag"
                            android:scaleType="centerCrop"
                            android:src="@drawable/flag_bsl" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#668A9BA7"
                            android:gravity="bottom|start"
                            android:orientation="vertical"
                            android:paddingStart="18dp"
                            android:paddingTop="18dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/sf_pro_bold"
                                android:includeFontPadding="false"
                                android:text="BSL"
                                android:textColor="#FFFFFF"
                                android:textSize="34sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/sf_pro_regular"
                                android:includeFontPadding="false"
                                android:text="British Sign Language"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/overlayCardAsl"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="ASL Flag"
                            android:scaleType="centerCrop"
                            android:src="@drawable/flag_asl" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#668A9BA7"
                            android:gravity="bottom|start"
                            android:orientation="vertical"
                            android:paddingStart="20dp"
                            android:paddingTop="20dp"
                            android:paddingEnd="20dp"
                            android:paddingBottom="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/sf_pro_bold"
                                android:includeFontPadding="false"
                                android:text="ASL"
                                android:textColor="#FFFFFF"
                                android:textSize="36sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/sf_pro_regular"
                                android:includeFontPadding="false"
                                android:text="American Sign Language"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:fontFamily="@font/sf_pro_medium"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="More language tutorials will be posted soon"
                    android:textColor="#7A7A7A"
                    android:textSize="14sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="140dp" />

            </LinearLayout>
        </ScrollView>
    </FrameLayout>
    <FrameLayout
        android:id="@+id/splashOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#F3F3F3"
        android:elevation="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:alpha="0"
            android:contentDescription="SaysAI Logo"
            android:scaleType="fitCenter"
            android:src="@mipmap/saysai_logo"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>