<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F3F3">

    <ImageView
        android:id="@+id/logo_image"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:contentDescription="SaysAI"
        android:src="@mipmap/saysai_logo"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tv_capture_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="24dp"
        android:text="Capture"
        android:textColor="#4A4A4A"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="@font/sf_pro_bold"
        android:letterSpacing="-0.01"
        android:includeFontPadding="false"
        app:layout_constraintEnd_toStartOf="@id/iv_settings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logo_image"/>

    <ImageView
        android:id="@+id/iv_settings"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="24dp"
        android:contentDescription="Settings"
        android:src="@drawable/ic_settings_home"
        app:layout_constraintBottom_toBottomOf="@id/tv_capture_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_capture_title"
        app:tint="#4A4A4A"/>

    <LinearLayout
        android:id="@+id/back_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_capture_title">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="Back"
            android:src="@drawable/ic_back_result"
            app:tint="#4A4A4A"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Translated Text"
            android:textColor="#4A4A4A"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/sf_pro_bold"
            android:includeFontPadding="false"/>

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/resultSentenceCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="24dp"
        app:cardBackgroundColor="#0D84A5"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/back_row">

        <TextView
            android:id="@+id/resultSentence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="18dp"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="@font/sf_pro_regular"
            android:includeFontPadding="false"/>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/resultSentenceCard">

        <TextView
            android:id="@+id/confidenceText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Average Accuracy Score: 0%"
            android:textColor="#A0A0A0"
            android:textSize="12sp"
            android:fontFamily="@font/sf_pro_regular"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/responseTimeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Average Response Time: 0 ms"
            android:textColor="#A0A0A0"
            android:textSize="12sp"
            android:fontFamily="@font/sf_pro_regular"
            android:includeFontPadding="false" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/action_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statsRow">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="110dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="#3fb1e5"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:id="@+id/btn_translate"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Translate"
                    android:src="@drawable/ic_translate_result"
                    app:tint="#FFFFFF" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="#FFFFFF" />

                <ImageView
                    android:id="@+id/btn_copy"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Copy"
                    android:src="@drawable/ic_copy_result"
                    app:tint="#FFFFFF" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/recordMoreButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="Record More"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:letterSpacing="-0.01"
            android:fontFamily="@font/sf_pro_medium"
            app:backgroundTint="#3fb1e5"
            app:cornerRadius="20dp"/>

    </LinearLayout>

    <TextView
        android:id="@+id/bleuInfoText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="24dp"
        android:text="BLEU Scores will be available once NLP is integrated in refining grammar structures and context."
        android:textColor="#8A8A8A"
        android:textSize="12sp"
        android:fontFamily="@font/sf_pro_regular"
        android:includeFontPadding="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/action_row" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/finishButton"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="24dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:text="Finish"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:letterSpacing="-0.01"
        android:fontFamily="@font/sf_pro_bold"
        app:backgroundTint="#0D84A5"
        app:cornerRadius="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bleuInfoText"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_nav"
        android:layout_width="wrap_content"
        android:layout_height="70dp"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="#0D84A5"
        app:cardCornerRadius="35dp"
        app:cardElevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="8dp"
            android:paddingEnd="18dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/navHome"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginEnd="26dp"
                android:background="@android:color/transparent"
                android:padding="4dp"
                android:src="@drawable/ic_nav_home"
                app:tint="@android:color/white"/>

            <ImageView
                android:id="@+id/navCamera"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="26dp"
                android:background="@drawable/nav_selected_circle"
                android:padding="10dp"
                android:src="@drawable/ic_nav_camera"
                app:tint="#0D84A5"/>

            <ImageView
                android:id="@+id/navArchive"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@android:color/transparent"
                android:padding="4dp"
                android:src="@drawable/ic_nav_archive"
                app:tint="@android:color/white"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>