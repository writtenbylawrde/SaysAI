<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F3F3"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:contentDescription="SaysAI"
        android:src="@mipmap/saysai_logo"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvCaptureTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:text="Capture"
        android:textColor="#4A4A4A"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="@font/sf_pro_bold"
        android:letterSpacing="-0.01"
        android:includeFontPadding="false"
        app:layout_constraintEnd_toStartOf="@id/ivSettings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logoImage"/>

    <ImageView
        android:id="@+id/ivSettings"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="24dp"
        android:contentDescription="Settings"
        android:src="@drawable/ic_settings_home"
        app:layout_constraintBottom_toBottomOf="@id/tvCaptureTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvCaptureTitle"
        app:tint="#4A4A4A"/>

    <LinearLayout
        android:id="@+id/leftHandToggleRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCaptureTitle">

        <TextView
            android:id="@+id/tvLeftHandLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Left-hand mode"
            android:textColor="#7A7A7A"
            android:textSize="14sp"
            android:fontFamily="@font/sf_pro_medium"
            android:includeFontPadding="false" />

        <Switch
            android:id="@+id/switchLeftHandMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:checked="false"
            android:showText="false"
            android:minWidth="44dp"
            android:minHeight="24dp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cameraCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="24dp"
        app:cardBackgroundColor="#3fb1e5"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/chipScrollView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/leftHandToggleRow">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="14dp">

            <androidx.camera.view.PreviewView
                android:id="@+id/previewView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="10dp"
                android:background="@drawable/camera_border"/>

            <TextView
                android:id="@+id/resultText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="50dp"
                android:gravity="center"
                android:text="Show open palm to start..."
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/sf_pro_medium"
                android:includeFontPadding="false"/>

        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Collected signs chips -->
    <HorizontalScrollView
        android:id="@+id/chipScrollView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="24dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cameraCard"
        app:layout_constraintBottom_toTopOf="@id/recordButton">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="2dp"/>

    </HorizontalScrollView>

    <!-- Buttons row -->
    <LinearLayout
        android:id="@+id/recordButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginEnd="10dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="26dp"
            android:paddingEnd="26dp"
            android:text="Clear"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/sf_pro_medium"
            android:letterSpacing="-0.01"
            app:backgroundTint="#3fb1e5"
            app:cornerRadius="20dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/doneButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"
            android:text="Done"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/sf_pro_bold"
            android:letterSpacing="-0.01"
            app:backgroundTint="#0D84A5"
            app:cornerRadius="20dp"/>

    </LinearLayout>

    <!-- Bottom nav -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNav"
        android:layout_width="wrap_content"
        android:layout_height="70dp"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="#0D84A5"
        app:cardCornerRadius="35dp"
        app:cardElevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="8dp"
            android:paddingEnd="18dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/navHome"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginEnd="26dp"
                android:background="@android:color/transparent"
                android:padding="4dp"
                android:src="@drawable/ic_nav_home"
                app:tint="@android:color/white"/>

            <ImageView
                android:id="@+id/navCamera"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="26dp"
                android:background="@drawable/nav_selected_circle"
                android:padding="10dp"
                android:src="@drawable/ic_nav_camera"
                app:tint="#0D84A5"/>

            <ImageView
                android:id="@+id/navArchive"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@android:color/transparent"
                android:padding="4dp"
                android:src="@drawable/ic_nav_archive"
                app:tint="@android:color/white"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>